--- a/quickjs-libc.c
+++ b/quickjs-libc.c
@@ -4508,3 +4508,4 @@ JSModuleDef *js_init_module_bjson(JSContext *ctx, const char *module_name)
     JS_AddModuleExportList(ctx, m, js_bjson_funcs, countof(js_bjson_funcs));
